COMPOSE_PROJECT_NAME=editdocs

#PHP && NGINX
SERVER_NAME=editdocs.local

#PHP
PHP_XDEBUG_CLIENT_HOST=host.docker.internal
PHP_XDEBUG_CLIENT_PORT=9000
PHP_XDEBUG_START_WITH_REQUEST=yes
PHP_XDEBUG_MODE=debug

#Nginx
NGINX_HTTP_PORT=80

#Mysql database
MYSQL_ROOT_PASSWORD=12345678
MYSQL_DATABASE=db_editdocs
MYSQL_USER=user_editdocs
MYSQL_PASSWORD=password_editdocs
MYSQL_PORT=3318